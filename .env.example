# 로컬 PostgreSQL (참고용 — docker-compose.yml 에서 주로 사용)
DATABASE_URL=postgres://hanwha:hanwha_local@localhost:5432/hanwhagreen

# --- 4단계: 관리자 에러 알림 (로컬) ---
ADMIN_NOTIFY_ENABLED=1
NOTIFY_PROVIDER=kakao
NOTIFY_ENV_LABEL=local
NOTIFY_LINK_URL=http://localhost:8081
# NOTIFY_COOLDOWN_MS=300000
# DB_HEALTH_CHECK_MS=15000

# 카카오 나에게 보내기 (docs/카카오_알림_설정.md 참고)
KAKAO_REST_API_KEY=
# 클라이언트 시크릿 ON 인 앱만 (앱 키 → REST API 키 → 클라이언트 시크릿)
# KAKAO_CLIENT_SECRET=
KAKAO_REFRESH_TOKEN=

# 카카오 실패 시 대체 (NOTIFY_PROVIDER=telegram)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
