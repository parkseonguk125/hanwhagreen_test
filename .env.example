# 로컬 PostgreSQL (참고용 — docker-compose.yml 에서 주로 사용)
DATABASE_URL=postgres://hanwha:hanwha_local@localhost:5432/hanwhagreen

# --- 4단계: 관리자 에러 알림 (로컬) ---
ADMIN_NOTIFY_ENABLED=1
NOTIFY_PROVIDER=kakao
NOTIFY_ENV_LABEL=local
NOTIFY_LINK_URL=http://localhost:8081
# NOTIFY_COOLDOWN_MS=300000
# DB_HEALTH_CHECK_MS=15000

# --- 모의해킹 대비 (docs/모의해킹_대비훈련_개요.md) ---
# SECURITY_LOGIN_MAX=10
# SECURITY_LOGIN_WINDOW_MS=900000
# SECURITY_LOGIN_LOCKOUT_MS=300000
# SECURITY_FAILED_LOGIN_NOTIFY=5
# SECURITY_NOTIFY_MIN_SEVERITY=2

# 카카오 나에게 보내기 (docs/카카오_알림_설정.md 참고)
KAKAO_REST_API_KEY=
# 클라이언트 시크릿 ON 인 앱만 (앱 키 → REST API 키 → 클라이언트 시크릿)
# KAKAO_CLIENT_SECRET=
KAKAO_REFRESH_TOKEN=

# 카카오 실패 시 대체 (NOTIFY_PROVIDER=telegram)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- 홈 실시간 정보 (공개 API) ---
# 공공데이터포털 일반 인증키 (Decoding) — 기상청·에어코리아 활용신청 후 사용
DATA_GO_KR_SERVICE_KEY=
# LIVE_DATA_CACHE_MS=600000

# 한국투자증권 Open API — 실시간 주가 (https://apiportal.koreainvestment.com)
KIS_APP_KEY=
KIS_APP_SECRET=
# KIS_USE_VTS=1
# KIS_STOCK_CACHE_MS=30000

# 프론트 빌드용 — NCP Maps Web Dynamic Map Client ID (docker compose build 시 web 이미지에 주입)
# VITE_NAVER_MAP_CLIENT_ID=

# --- 출결 Flutter 앱 연동 (docs/출격서비스_0단계_사전준비.md) ---
# 앱 POST /api/attendance 시 X-App-Key 헤더와 비교 (랜덤 긴 문자열)
# ATTENDANCE_APP_API_KEY=
# 출결 현장 사진 저장 (Docker api 컨테이너 경로, 1단계에서 볼륨 연결)
# ATTENDANCE_UPLOAD_DIR=/app/uploads/attendance
# NCP Maps Mobile Dynamic Map Client ID (웹 VITE_NAVER_MAP_CLIENT_ID 와 별도 발급)
# Android 패키지명: com.hanwhagreen.hanwha_attendance
# NAVER_MAP_CLIENT_ID=
# 출결 앱 APK 빌드 시 API 주소 (끝에 /api 포함, 태블릿이 접속할 서버)
# 로컬 Wi-Fi 테스트: http://192.168.0.10:3001/api  (PC IP로 변경)
# AWS 배포: https://your-domain.duckdns.org/api  (출결서비스_AWS배포.bat 사용)
# ATTENDANCE_APP_API_BASE_URL=
