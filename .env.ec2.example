# EC2 서버용 .env 예시 (WinSCP로 ~/hanwhagreen_test/.env 에 업로드)
# 생성 도움: 출결서비스_AWS배포.bat 또는 scripts/prepare-aws-deploy.ps1

# --- 알림 ---
ADMIN_NOTIFY_ENABLED=1
NOTIFY_PROVIDER=kakao
NOTIFY_ENV_LABEL=ec2
# HTTPS 적용 후 도메인으로 변경 (끝에 / 포함)
NOTIFY_LINK_URL=https://hanwhagreentest.duckdns.org/

# 카카오 나에게 보내기 (로컬 .env 와 동일 값 복사)
KAKAO_REST_API_KEY=
KAKAO_REFRESH_TOKEN=
# KAKAO_CLIENT_SECRET=

# --- 홈페이지 빌드 (docker compose build 시 web 이미지에 주입) ---
VITE_NAVER_MAP_CLIENT_ID=

# --- 출결 앱 API (서버에서 X-App-Key 검증) ---
# 로컬 .env 의 ATTENDANCE_APP_API_KEY 와 반드시 동일
ATTENDANCE_APP_API_KEY=
ATTENDANCE_UPLOAD_DIR=/app/uploads/attendance

# --- 선택: 공공 API / 주가 ---
# DATA_GO_KR_SERVICE_KEY=
# KIS_APP_KEY=
# KIS_APP_SECRET=

# 참고: ATTENDANCE_APP_API_BASE_URL 은 APK 빌드용(PC .env) — EC2 .env 에는 넣지 않음
